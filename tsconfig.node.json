{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "scripts/**/*.ts",
    "src/game/constants/**/*.ts",
    "src/game/rules/**/*.ts",
    "src/game/simulation/**/*.ts",
    "src/game/types.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
